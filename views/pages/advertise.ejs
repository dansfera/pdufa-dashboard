<%- include('../partials/header') %>

<!-- Page Header -->
<div class="bg-gradient-to-r from-earth-800 to-earth-700 text-white py-12" style="background:linear-gradient(to right,#432f19,#5e4625)">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div class="text-4xl mb-3">&#127797;</div>
    <h1 class="text-3xl sm:text-4xl font-bold font-heading mb-3">Advertise With Us</h1>
    <p class="text-earth-200 text-lg max-w-2xl mx-auto">Reach homeowners actively searching for pest control services in the Sunbelt. Your business, in front of the right audience.</p>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

  <!-- Audience Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold font-heading text-earth-800 mb-4">Our Audience</h2>
    <p class="text-gray-600 mb-6 leading-relaxed">Sunbelt Pest Guide attracts local homeowners who are actively researching pest control solutions. These are high-intent visitors — people with a real problem looking for a trusted solution, not casual browsers.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
      <div class="bg-sunbelt-50 border border-sunbelt-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-sunbelt-700 mb-1">5</div>
        <div class="text-sm text-earth-600 font-medium">Sunbelt Cities Covered</div>
        <div class="text-xs text-earth-500 mt-1">Yuma, Tucson, Tulsa, Greenville, Kansas City</div>
      </div>
      <div class="bg-sunbelt-50 border border-sunbelt-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-sunbelt-700 mb-1">21+</div>
        <div class="text-sm text-earth-600 font-medium">Informational Pages</div>
        <div class="text-xs text-earth-500 mt-1">City guides, pest type pages &amp; articles</div>
      </div>
      <div class="bg-sunbelt-50 border border-sunbelt-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-sunbelt-700 mb-1">100%</div>
        <div class="text-sm text-earth-600 font-medium">Local Homeowners</div>
        <div class="text-xs text-earth-500 mt-1">Organic search traffic, high buyer intent</div>
      </div>
    </div>

    <div class="bg-white border border-earth-200 rounded-xl p-6">
      <h3 class="font-semibold text-earth-800 mb-3">Cities We Reach</h3>
      <div class="flex flex-wrap gap-2">
        <% cities.forEach(function(c) { %>
          <span class="bg-earth-100 text-earth-700 px-3 py-1 rounded-full text-sm"><%= c.fullName %></span>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Ad Options Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold font-heading text-earth-800 mb-4">Advertising Options</h2>
    <p class="text-gray-600 mb-6">We offer flexible, affordable advertising placements that get your pest control business seen by local homeowners who need your services.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">

      <div class="bg-white border border-earth-200 rounded-xl p-6 hover:border-sunbelt-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-3">🏷️</div>
        <h3 class="font-bold text-earth-800 text-lg mb-2">Banner Ads</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Prominent display ads placed throughout city pages, pest guides, and article pages. Available in standard IAB sizes.</p>
        <ul class="mt-3 space-y-1 text-sm text-earth-600">
          <li>✓ Header &amp; sidebar placements</li>
          <li>✓ In-content placements</li>
          <li>✓ Mobile-optimized</li>
        </ul>
      </div>

      <div class="bg-white border border-earth-200 rounded-xl p-6 hover:border-sunbelt-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-3">⭐</div>
        <h3 class="font-bold text-earth-800 text-lg mb-2">Sponsored Listings</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Get your business listed as a recommended provider on relevant city and pest-type pages. Includes your business name, description, and contact link.</p>
        <ul class="mt-3 space-y-1 text-sm text-earth-600">
          <li>✓ City-specific pages</li>
          <li>✓ Pest-type pages</li>
          <li>✓ Clearly labeled as sponsored</li>
        </ul>
      </div>

      <div class="bg-white border border-sunbelt-300 rounded-xl p-6 shadow-sm relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-sunbelt-500 text-white text-xs font-semibold px-3 py-1 rounded-full">Most Popular</div>
        <div class="text-3xl mb-3">🔝</div>
        <h3 class="font-bold text-earth-800 text-lg mb-2">Featured Placement</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Top-of-page featured position on city landing pages and pest-type guides. Maximum visibility for the markets you serve.</p>
        <ul class="mt-3 space-y-1 text-sm text-earth-600">
          <li>✓ Above-the-fold placement</li>
          <li>✓ Target specific cities</li>
          <li>✓ Logo + description + CTA</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Why Advertise Section -->
  <section class="mb-12">
    <div class="bg-earth-800 text-white rounded-2xl p-8">
      <h2 class="text-2xl font-bold font-heading mb-4">Why Advertise on Sunbelt Pest Guide?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <span class="text-sunbelt-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Targeted Local Traffic</div>
            <div class="text-earth-300 text-sm">Every visitor is searching for pest control in a specific Sunbelt city — not national browsing.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-sunbelt-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">High Buyer Intent</div>
            <div class="text-earth-300 text-sm">People reading about scorpion removal or termite treatment are ready to hire. These aren't window shoppers.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-sunbelt-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Niche Authority</div>
            <div class="text-earth-300 text-sm">We focus exclusively on Sunbelt pest control — building trust with the exact homeowners you want to reach.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-sunbelt-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Simple &amp; Transparent</div>
            <div class="text-earth-300 text-sm">No complex auction systems. Direct partnership, fair pricing, and honest reporting.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="contact">
    <h2 class="text-2xl font-bold font-heading text-earth-800 mb-2">Get In Touch</h2>
    <p class="text-gray-600 mb-6">Fill out the form below and we'll get back to you within 1-2 business days with pricing and availability.</p>

    <% if (typeof formSuccess !== 'undefined' && formSuccess) { %>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6 text-center mb-6">
        <div class="text-4xl mb-2">✅</div>
        <h3 class="text-lg font-semibold text-green-800 mb-1">Message Sent!</h3>
        <p class="text-green-700 text-sm">Thanks for reaching out. We'll get back to you within 1-2 business days.</p>
      </div>
    <% } else if (typeof formError !== 'undefined' && formError) { %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
        <p class="text-red-700 text-sm"><%= formError %></p>
      </div>
    <% } %>

    <% if (typeof formSuccess === 'undefined' || !formSuccess) { %>
    <form action="/advertise" method="POST" class="bg-white border border-earth-200 rounded-2xl p-6 sm:p-8 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-semibold text-earth-700 mb-1.5" for="name">Your Name <span class="text-red-500">*</span></label>
          <input type="text" id="name" name="name" required placeholder="Jane Smith"
            class="w-full border border-earth-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sunbelt-400 focus:border-transparent transition-all"
            value="<%= typeof formValues !== 'undefined' ? formValues.name : '' %>">
        </div>
        <div>
          <label class="block text-sm font-semibold text-earth-700 mb-1.5" for="business_name">Business Name <span class="text-red-500">*</span></label>
          <input type="text" id="business_name" name="business_name" required placeholder="Acme Pest Control"
            class="w-full border border-earth-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sunbelt-400 focus:border-transparent transition-all"
            value="<%= typeof formValues !== 'undefined' ? formValues.business_name : '' %>">
        </div>
      </div>
      <div>
        <label class="block text-sm font-semibold text-earth-700 mb-1.5" for="email">Email Address <span class="text-red-500">*</span></label>
        <input type="email" id="email" name="email" required placeholder="jane@acmepest.com"
          class="w-full border border-earth-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sunbelt-400 focus:border-transparent transition-all"
          value="<%= typeof formValues !== 'undefined' ? formValues.email : '' %>">
      </div>
      <div>
        <label class="block text-sm font-semibold text-earth-700 mb-1.5" for="message">Tell Us About Your Business <span class="text-red-500">*</span></label>
        <textarea id="message" name="message" required rows="4" placeholder="Which cities do you serve? What types of pests? What kind of advertising are you interested in?"
          class="w-full border border-earth-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sunbelt-400 focus:border-transparent transition-all resize-none"><%= typeof formValues !== 'undefined' ? formValues.message : '' %></textarea>
      </div>
      <button type="submit"
        class="w-full sm:w-auto bg-sunbelt-500 hover:bg-sunbelt-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors text-sm shadow-sm hover:shadow">
        Send Inquiry &rarr;
      </button>
    </form>
    <% } %>
  </section>

</div>

<%- include('../partials/footer') %>
