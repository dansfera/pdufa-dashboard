<%- include('../partials/header', { title, metaDescription, canonicalUrl, cities, pests, analyticsSlug }) %>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-earth-700 via-earth-800 to-earth-900 text-white py-16 md:py-24" style="background:linear-gradient(to bottom right,#5e4625,#432f19,#2d1f10)">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight font-heading">
        Your Complete <span class="text-sunbelt-400">Sunbelt</span> Pest Control Guide
      </h1>
      <p class="text-xl md:text-2xl text-earth-200 max-w-3xl mx-auto mb-10">
        Expert pest control information for homeowners across the Sunbelt region. Local guides, treatment costs, and prevention tips — no sales pitches, just real answers.
      </p>

      <!-- City Selector -->
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <% cities.forEach(c => { %>
          <a href="/<%= c.slug %>/" class="px-5 py-2.5 bg-white/10 hover:bg-sunbelt-500 hover:text-earth-900 rounded-full text-white font-medium transition-all duration-200 backdrop-blur-sm border border-white/20 hover:border-sunbelt-500">
            <%= c.fullName %>
          </a>
        <% }) %>
      </div>
      <p class="text-earth-400 text-sm">5 cities covered &bull; 9 pest types &bull; Updated for 2026</p>
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-earth-800 mb-8 font-heading">Latest Guides</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% articles.slice(0, 6).forEach(a => { %>
          <% const articleCity = cities.find(c => c.slug === a.city); %>
          <article class="bg-white rounded-xl shadow-sm border border-earth-200 hover:shadow-md hover:border-earth-300 transition-all duration-200 overflow-hidden group relative">
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-sunbelt-600 bg-sunbelt-50 px-2 py-0.5 rounded-full">
                  <%= articleCity ? articleCity.fullName : '' %>
                </span>
                <span class="text-xs text-gray-400"><%= a.readTime %></span>
              </div>
              <h3 class="font-bold text-lg text-earth-800 group-hover:text-sunbelt-700 transition-colors mb-2 line-clamp-2">
                <a href="/<%= a.city %>/<%= a.slug %>/" class="after:absolute after:inset-0 relative">
                  <%= a.title %>
                </a>
              </h3>
              <p class="text-gray-600 text-sm line-clamp-3"><%= a.excerpt %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('../partials/ad-inline') %>

  <!-- Cities Section -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-earth-800 mb-3 font-heading">Browse by City</h2>
      <p class="text-gray-600 mb-8 max-w-2xl">Get pest control information specific to your area — local pests, seasonal patterns, treatment costs, and prevention tips tailored to your city's climate.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% cities.forEach(c => { %>
          <a href="/<%= c.slug %>/" class="block bg-earth-50 rounded-xl p-6 hover:bg-earth-100 border border-earth-200 hover:border-earth-300 transition-all group">
            <h3 class="text-xl font-bold text-earth-800 group-hover:text-sunbelt-700 mb-2"><%= c.fullName %></h3>
            <p class="text-gray-600 text-sm mb-3"><%= c.climate %></p>
            <div class="flex flex-wrap gap-1.5">
              <% c.topPests.slice(0, 4).forEach(pest => { %>
                <span class="text-xs bg-earth-200 text-earth-700 px-2 py-0.5 rounded-full"><%= pest %></span>
              <% }) %>
            </div>
            <p class="text-sunbelt-600 text-sm font-medium mt-3 group-hover:text-sunbelt-700">View local guide &rarr;</p>
          </a>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('../partials/ad-adsterra') %>

  <!-- Pest Types Section -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-earth-800 mb-3 font-heading">Browse by Pest Type</h2>
      <p class="text-gray-600 mb-8 max-w-2xl">Learn about specific pests — identification, danger levels, treatment options, and prevention strategies.</p>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% pests.forEach(p => { %>
          <a href="/pests/<%= p.slug %>/" class="block bg-white rounded-xl p-5 hover:shadow-md border border-earth-200 hover:border-sunbelt-300 transition-all text-center group">
            <span class="text-3xl block mb-2"><%= p.icon %></span>
            <h3 class="font-semibold text-earth-800 group-hover:text-sunbelt-700"><%= p.name %></h3>
            <p class="text-xs text-gray-500 mt-1"><%= p.shortDesc %></p>
          </a>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('../partials/ad-adsterra') %>

  <!-- Trust Section -->
  <section class="py-12 bg-earth-100 border-t border-earth-200">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-earth-800 mb-4 font-heading">Why Trust Sunbelt Pest Guide?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <div class="p-4">
          <div class="text-3xl mb-3">&#128300;</div>
          <h3 class="font-semibold text-earth-800 mb-2">Research-Backed</h3>
          <p class="text-gray-600 text-sm">Our guides are based on entomological research, EPA guidelines, and local pest control industry data.</p>
        </div>
        <div class="p-4">
          <div class="text-3xl mb-3">&#128205;</div>
          <h3 class="font-semibold text-earth-800 mb-2">Locally Focused</h3>
          <p class="text-gray-600 text-sm">Each guide is tailored to your city's specific climate, pest populations, and seasonal patterns.</p>
        </div>
        <div class="p-4">
          <div class="text-3xl mb-3">&#128683;</div>
          <h3 class="font-semibold text-earth-800 mb-2">No Sales Pitches</h3>
          <p class="text-gray-600 text-sm">We don't sell pest control services. Just honest information to help you make informed decisions.</p>
        </div>
      </div>
    </div>
  </section>

<%- include('../partials/footer', { cities, pests, analyticsSlug }) %>
