<%- include('../partials/header') %>

<!-- Page Header -->
<div class="bg-gradient-to-r from-water-800 to-water-700 text-white py-12" style="background: linear-gradient(to right, #1e40af, #1d4ed8);">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div class="text-4xl mb-3">💧</div>
    <h1 class="text-3xl sm:text-4xl font-bold font-heading mb-3">Advertise With Us</h1>
    <p class="text-blue-200 text-lg max-w-2xl mx-auto">Reach homeowners actively searching for water damage restoration services in the Sunbelt. Your business, in front of the right audience — right when they need you most.</p>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

  <!-- Audience Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold font-heading text-slate-800 mb-4">Our Audience</h2>
    <p class="text-gray-600 mb-6 leading-relaxed">Sunbelt Restoration Guide attracts local homeowners facing water damage emergencies and restoration needs. These are high-urgency visitors — people with a real, time-sensitive problem who need a trusted professional immediately.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-blue-700 mb-1">5</div>
        <div class="text-sm text-slate-600 font-medium">Sunbelt Cities Covered</div>
        <div class="text-xs text-slate-500 mt-1">Yuma, Tucson, Tulsa, Greenville, Kansas City</div>
      </div>
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-blue-700 mb-1">21+</div>
        <div class="text-sm text-slate-600 font-medium">Informational Pages</div>
        <div class="text-xs text-slate-500 mt-1">City guides, service pages &amp; in-depth articles</div>
      </div>
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-blue-700 mb-1">$50–200+</div>
        <div class="text-sm text-slate-600 font-medium">Cost Per Click Value</div>
        <div class="text-xs text-slate-500 mt-1">Restoration keywords among highest-value CPCs</div>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-6">
      <h3 class="font-semibold text-slate-800 mb-3">Cities We Reach</h3>
      <div class="flex flex-wrap gap-2">
        <% cities.forEach(function(c) { %>
          <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-sm"><%= c.fullName %></span>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Ad Options Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold font-heading text-slate-800 mb-4">Advertising Options</h2>
    <p class="text-gray-600 mb-6">We offer flexible advertising placements that get your restoration business seen by local homeowners the moment they need help.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">

      <div class="bg-white border border-slate-200 rounded-xl p-6 hover:border-blue-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-3">🏷️</div>
        <h3 class="font-bold text-slate-800 text-lg mb-2">Banner Ads</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Display ads placed throughout city pages and service guides. Available in standard IAB sizes, mobile-optimized.</p>
        <ul class="mt-3 space-y-1 text-sm text-slate-600">
          <li>✓ Header &amp; sidebar placements</li>
          <li>✓ In-content placements</li>
          <li>✓ Mobile-optimized</li>
        </ul>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-6 hover:border-blue-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-3">⭐</div>
        <h3 class="font-bold text-slate-800 text-lg mb-2">Sponsored Listings</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Listed as a recommended provider on city and service-type pages. Business name, description, and contact link included.</p>
        <ul class="mt-3 space-y-1 text-sm text-slate-600">
          <li>✓ City-specific pages</li>
          <li>✓ Service category pages</li>
          <li>✓ Clearly labeled as sponsored</li>
        </ul>
      </div>

      <div class="bg-white border border-blue-300 rounded-xl p-6 shadow-sm relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-blue-600 text-white text-xs font-semibold px-3 py-1 rounded-full">Most Popular</div>
        <div class="text-3xl mb-3">🔝</div>
        <h3 class="font-bold text-slate-800 text-lg mb-2">Featured Placement</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Top-of-page featured position on city landing pages and service guides. Maximum visibility when it matters most.</p>
        <ul class="mt-3 space-y-1 text-sm text-slate-600">
          <li>✓ Above-the-fold placement</li>
          <li>✓ Target specific cities</li>
          <li>✓ Logo + description + CTA</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Why Advertise Section -->
  <section class="mb-12">
    <div class="bg-slate-800 text-white rounded-2xl p-8">
      <h2 class="text-2xl font-bold font-heading mb-4">Why Advertise on Sunbelt Restoration Guide?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <span class="text-blue-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Emergency-Intent Traffic</div>
            <div class="text-slate-300 text-sm">Water damage visitors are in crisis mode — they need help NOW and are ready to call immediately.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-blue-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Premium Service Niche</div>
            <div class="text-slate-300 text-sm">Restoration jobs average $3,000–$10,000+. One lead can pay for months of advertising.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-blue-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Targeted Local Coverage</div>
            <div class="text-slate-300 text-sm">We cover the exact Sunbelt cities where water damage calls spike — Yuma, Tucson, Tulsa, Greenville, and Kansas City.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-blue-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">No Middlemen</div>
            <div class="text-slate-300 text-sm">Direct advertising relationship. No aggregators, no referral fees, no shared leads.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="contact">
    <h2 class="text-2xl font-bold font-heading text-slate-800 mb-2">Get In Touch</h2>
    <p class="text-gray-600 mb-6">Fill out the form below and we'll get back to you within 1-2 business days with pricing and availability.</p>

    <% if (typeof formSuccess !== 'undefined' && formSuccess) { %>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6 text-center mb-6">
        <div class="text-4xl mb-2">✅</div>
        <h3 class="text-lg font-semibold text-green-800 mb-1">Message Sent!</h3>
        <p class="text-green-700 text-sm">Thanks for reaching out. We'll get back to you within 1-2 business days.</p>
      </div>
    <% } else if (typeof formError !== 'undefined' && formError) { %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
        <p class="text-red-700 text-sm"><%= formError %></p>
      </div>
    <% } %>

    <% if (typeof formSuccess === 'undefined' || !formSuccess) { %>
    <form action="/restoration/advertise" method="POST" class="bg-white border border-slate-200 rounded-2xl p-6 sm:p-8 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="name">Your Name <span class="text-red-500">*</span></label>
          <input type="text" id="name" name="name" required placeholder="Jane Smith"
            class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all"
            value="<%= typeof formValues !== 'undefined' ? formValues.name : '' %>">
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="business_name">Business Name <span class="text-red-500">*</span></label>
          <input type="text" id="business_name" name="business_name" required placeholder="Acme Restoration"
            class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all"
            value="<%= typeof formValues !== 'undefined' ? formValues.business_name : '' %>">
        </div>
      </div>
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="email">Email Address <span class="text-red-500">*</span></label>
        <input type="email" id="email" name="email" required placeholder="jane@acmerestoration.com"
          class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all"
          value="<%= typeof formValues !== 'undefined' ? formValues.email : '' %>">
      </div>
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="message">Tell Us About Your Business <span class="text-red-500">*</span></label>
        <textarea id="message" name="message" required rows="4" placeholder="Which cities do you serve? What restoration services do you offer? What kind of advertising are you interested in?"
          class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all resize-none"><%= typeof formValues !== 'undefined' ? formValues.message : '' %></textarea>
      </div>
      <button type="submit"
        class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors text-sm shadow-sm hover:shadow">
        Send Inquiry &rarr;
      </button>
    </form>
    <% } %>
  </section>

</div>

<%- include('../partials/footer') %>
