<script>
// Substack banner dismiss (localStorage-based, 30-day)
(function() {
  var KEY = 'pdufa_sub_dismissed';
  var banner = document.getElementById('substack-banner');
  var dismissed = false;
  try {
    var ts = localStorage.getItem(KEY);
    if (ts && (Date.now() - parseInt(ts, 10)) < 30 * 24 * 60 * 60 * 1000) dismissed = true;
  } catch(e) {}
  if (dismissed && banner) {
    banner.classList.add('hidden');
    showNavMini();
  }
})();

function dismissSubstackBanner() {
  var banner = document.getElementById('substack-banner');
  if (banner) banner.classList.add('hidden');
  try { localStorage.setItem('pdufa_sub_dismissed', Date.now().toString()); } catch(e) {}
  showNavMini();
}

function showNavMini() {
  // After dismiss, reveal the small nav link (if present)
  var mini = document.getElementById('substack-nav-mini');
  if (mini) mini.classList.add('visible');
}

function filterCards(type, btn) {
  // Update active tab
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');

  const cards = document.querySelectorAll('.pdufa-card');
  let visibleCount = 0;

  cards.forEach(card => {
    let show = false;
    if (type === 'all') {
      show = true;
    } else {
      show = card.dataset.catalyst === type;
    }
    card.style.display = show ? 'block' : 'none';
    if (show) visibleCount++;
  });

  // Show/hide no-results message
  const noResults = document.getElementById('no-results');
  if (noResults) {
    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  // Also hide/show section headers that become empty
  const pastSection = document.querySelector('[data-section="past"]');
  // (future enhancement: smart section hiding)
}

// Analytics: backup CTA click tracking (primary tracking is via /go/substack redirect)
// Uses renamed endpoint /api/evt to avoid ad-blocker filter lists
function trackCtaClick(placement) {
  try {
    var payload = JSON.stringify({
      event_type: 'cta_click',
      placement: placement,
      page: window.location.pathname
    });
    if (navigator.sendBeacon) {
      var blob = new Blob([payload], { type: 'application/json' });
      navigator.sendBeacon('/api/evt', blob);
    } else {
      fetch('/api/evt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: payload,
        keepalive: true
      }).catch(function() {});
    }
  } catch(e) {}
}
</script>

