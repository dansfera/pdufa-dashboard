<%- include('../partials/head') %>
<%- include('../partials/header') %>

<style>
  .hbchap { max-width: 760px; margin: 0 auto; padding: 8px 0 64px; }
  .hbchap .back { display: inline-block; font-size: 14px; font-weight: 600; color: var(--accent-teal); text-decoration: none; margin: 4px 0 24px; }
  .hbchap .back:hover { text-decoration: underline; }
  .hbchap .eyebrow { text-transform: uppercase; letter-spacing: 0.16em; font-size: 12px; font-weight: 700; color: var(--text-muted); margin-bottom: 12px; }
  .hbchap h1 { font-size: clamp(34px, 6vw, 56px); font-weight: 900; letter-spacing: -0.02em; line-height: 1.02; margin: 0 0 14px; }
  .hbchap .subtitle { font-size: clamp(18px, 3vw, 23px); font-weight: 500; color: var(--text-primary); line-height: 1.35; margin: 0 0 26px; }
  .hbchap .rule { height: 1px; background: var(--border); border: 0; margin: 30px 0; }
  .hbchap .body { font-size: 18px; line-height: 1.75; color: var(--text-secondary); margin: 0 0 20px; }
  .hbchap .note { font-size: 14px; color: var(--text-muted); font-style: italic; margin: 0 0 8px; }
  .hbchap .chap-nav { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin: 36px 0 0; border-top: 1px solid var(--border); padding-top: 20px; }
  .hbchap .chap-nav a { font-size: 15px; font-weight: 600; color: var(--text-primary); text-decoration: none; max-width: 46%; }
  .hbchap .chap-nav a:hover { color: var(--accent-teal); }
  .hbchap .chap-nav a.next { text-align: right; margin-left: auto; }
  .hbchap .all-link { margin: 26px 0 0; }
  .hbchap .all-link a { font-size: 15px; font-weight: 600; color: var(--accent-teal); text-decoration: none; }
</style>

<div class="hbchap">
  <a class="back" href="<%= typeof appBase !== 'undefined' ? appBase : '' %>/hatbook">&larr; ALL CAPS: The History of the American Baseball Hat</a>

  <div class="eyebrow">Chapter <%= chapter.num %> &middot; A book in progress by Dan Sfera</div>
  <h1><%= chapter.title %></h1>
  <p class="subtitle"><%= chapter.teaser %></p>

  <hr class="rule" />

  <p class="body"><%= chapter.blurb %></p>
  <p class="note">A chapter preview from ALL CAPS: THE HISTORY OF THE AMERICAN BASEBALL HAT, a book in progress. Full chapter text is not yet public.</p>

  <%- include('../partials/book-signup') %>

  <nav class="chap-nav">
    <% if (typeof prev !== 'undefined' && prev) { %>
      <a href="<%= typeof appBase !== 'undefined' ? appBase : '' %>/hatbook/chapter/<%= prev.slug %>">&larr; Ch <%= prev.num %>: <%= prev.title %></a>
    <% } %>
    <% if (typeof next !== 'undefined' && next) { %>
      <a class="next" href="<%= typeof appBase !== 'undefined' ? appBase : '' %>/hatbook/chapter/<%= next.slug %>">Ch <%= next.num %>: <%= next.title %> &rarr;</a>
    <% } %>
  </nav>

  <p class="all-link"><a href="<%= typeof appBase !== 'undefined' ? appBase : '' %>/hatbook">See all chapters &rarr;</a></p>
</div>

<%- include('../partials/footer') %>
