<%
function badgeClass(desig) {
  const d = desig.toLowerCase();
  if (d.includes('breakthrough')) return 'badge-breakthrough';
  if (d.includes('priority review')) return 'badge-priority';
  if (d.includes('orphan')) return 'badge-orphan';
  if (d.includes('fast track')) return 'badge-fasttrack';
  if (d.includes('accelerated')) return 'badge-accelerated';
  if (d.includes('rare pediatric') || d.includes('rare ped')) return 'badge-rare-ped';
  return 'badge-nda';
}
function poaClass(score) {
  if (!score) return 'poa-high';
  if (score >= 80) return 'poa-high';
  if (score >= 40) return 'poa-med';
  return 'poa-low';
}
%>
<%- include('../partials/head') %>

<!-- BreadcrumbList + MedicalEntity structured data for this catalyst page -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Biotech Catalyst Calendar",
          "item": "<%= BASE_URL %>/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "<%= (drug.brand_name || drug.drug_name || '').replace(/"/g, '&quot;') %>",
          "item": "<%= BASE_URL %>/drug/<%= drug.slug %>"
        }
      ]
    },
    {
      "@type": "Dataset",
      "name": "<%= title.replace(/"/g, '&quot;') %>",
      "description": "<%= metaDescription.replace(/"/g, '&quot;') %>",
      "url": "<%= BASE_URL %>/drug/<%= drug.slug %>",
      "author": {
        "@type": "Person",
        "name": "Dan Sfera",
        "sameAs": ["https://substack.com/@dansfera1", "https://x.com/dansfera"]
      },
      "about": {
        "@type": "Drug",
        "name": "<%= (drug.brand_name || drug.drug_name || '').replace(/"/g, '&quot;') %>"<% if (drug.company) { %>,
        "manufacturer": {
          "@type": "Organization",
          "name": "<%= drug.company.replace(/"/g, '&quot;') %>"
        }<% } %>
      }
    }
  ]
}
</script>

<%- include('../partials/header') %>

<div class="drug-detail">
  <a href="<%= typeof appBase !== 'undefined' ? appBase : '' %>/" class="back-link">← Back to Calendar</a>

  <!-- Drug Header Card -->
  <div class="drug-header">
    <div class="drug-header-grid">
      <div>
        <h1 class="drug-title">
          <%= drug.brand_name || drug.drug_name %>
          <% if (drug.brand_name) { %><span style="font-size: 18px; font-weight: 500; color: var(--text-secondary);"> (<%= drug.drug_name %>)</span><% } %>
        </h1>
        <div class="drug-subtitle"><%= drug.company %><% if (drug.ticker) { %> · <span class="card-cashtag" style="font-size: 13px;"><%= drug.cashtag || drug.ticker %></span><% } %></div>

        <div class="card-badges" style="margin-bottom: 0;">
          <span class="badge review-type-badge review-<%= drug.review_type %>">
            <%= drug.review_type === 'priority' ? 'Priority Review' : 'Standard Review' %>
          </span>
          <% if (drug.designation && drug.designation.length) {
            drug.designation.forEach(function(d) {
              if (d && d !== 'Priority Review') {
          %>
          <span class="badge <%= badgeClass(d) %>"><%= d %></span>
          <% }}) } %>
          <% if (drug.nda_bla_type) { %>
          <span class="badge badge-nda"><%= drug.nda_bla_type %></span>
          <% } %>
        </div>

        <div class="drug-meta-grid">
          <div class="meta-item">
            <div class="meta-label"><%= drug.catalyst_type === 'pdufa' ? 'PDUFA Date' : (drug.catalyst_type === 'adcom' ? 'AdCom Date' : 'Catalyst Date') %></div>
            <div class="meta-value" style="color: var(--accent-teal);"><%= drug.formattedDate %></div>
          </div>
          <div class="meta-item">
            <div class="meta-label"><%= drug.statusClass === 'overdue' ? 'Date Status' : 'Time Remaining' %></div>
            <div class="meta-value <%= drug.statusClass === 'overdue' ? 'poa-low' : (drug.statusClass === 'this-week' ? 'poa-med' : 'poa-high') %>">
              <%= drug.statusClass === 'overdue' ? drug.daysUntil + ' (past)' : drug.daysUntil %>
            </div>
          </div>
          <div class="meta-item">
            <div class="meta-label">Review Type</div>
            <div class="meta-value"><%= drug.review_type === 'priority' ? 'Priority (6 mo)' : 'Standard (10 mo)' %></div>
          </div>
          <% if (drug.filing_date) { %>
          <div class="meta-item">
            <div class="meta-label">Filed</div>
            <div class="meta-value"><%= formatDate(drug.filing_date) %></div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- PoA Score -->
      <% if (drug.basePoA) { %>
      <div class="drug-poa-large">
        <div class="poa-large-num <%= poaClass(drug.basePoA) %>"><%= drug.basePoA %>%</div>
        <div class="poa-large-label">Baseline PoA</div>
        <div class="poa-large-note">
          <%= drug.poaRationale || 'FDA historical approval rate' %>
        </div>
        <div style="margin-top: 10px; font-size: 10px; color: var(--text-muted); line-height: 1.4;">
          Based on FDA historical approval rates by submission type (2015–2025)
        </div>
        <div style="margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border);">
          <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 4px;">Dynamic PoA</div>
          <div style="font-size: 12px; color: var(--text-muted);">Coming soon<br><span style="font-size: 10px;">xAI Sentiment</span></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- FDA Decision Section (past PDUFA/AdCom only) -->
  <% const isPastEntry = drug.statusClass === 'overdue' && (drug.catalyst_type === 'pdufa' || drug.catalyst_type === 'adcom'); %>
  <% if (isPastEntry) { %>
  <div class="fda-decision-section">
    <h2>FDA Decision</h2>
    <% if (drug.outcomeResult) { %>
    <div class="outcome-result-large outcome-result-large-<%= drug.outcomeClass %>">
      <div class="outcome-result-icon">
        <% if (drug.outcomeResult === 'approved') { %>✅<% } else if (drug.outcomeResult === 'crl') { %>❌<% } else if (drug.outcomeResult === 'delayed') { %>⏳<% } else { %>📋<% } %>
      </div>
      <div class="outcome-result-body">
        <div class="outcome-result-verdict outcome-result-verdict-<%= drug.outcomeClass %>">
          <%= drug.outcomeLabel %>
        </div>
        <% if (drug.outcome_date) { %>
        <div class="outcome-result-meta">Decision issued: <%= typeof formatDate !== 'undefined' ? formatDate(drug.outcome_date) : drug.outcome_date %></div>
        <% } else { %>
        <div class="outcome-result-meta">PDUFA date was <%= drug.formattedDate %></div>
        <% } %>
        <% if (drug.outcome_notes) { %>
        <div class="outcome-result-notes"><%= drug.outcome_notes %></div>
        <% } %>
        <% if (drug.outcome_source) { %>
        <div class="outcome-result-meta" style="margin-top: 6px;">Source: <%= drug.outcome_source %></div>
        <% } %>
      </div>
    </div>
    <% } else { %>
    <!-- No outcome recorded yet -->
    <div class="outcome-result-large outcome-result-large-unknown">
      <div class="outcome-result-icon">⏳</div>
      <div class="outcome-result-body">
        <div class="outcome-result-verdict outcome-result-verdict-unknown">Outcome Not Yet Recorded</div>
        <div class="outcome-result-meta">
          PDUFA date was <%= drug.formattedDate %> · This entry hasn't been updated with the FDA decision yet.
        </div>
        <div style="margin-top: 10px;">
          <a href="https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm" target="_blank" rel="noopener"
             style="font-size: 12px; color: var(--accent-teal); text-decoration: none;">
            ↗ Check FDA Drug Approval Database
          </a>
        </div>
      </div>
    </div>
    <% } %>
  </div>
  <% } %>

  <!-- Live Company Financial Data (FMP) -->
  <% if (typeof companyFinancials !== 'undefined' && companyFinancials) { %>
  <%
    var fin = companyFinancials;
    var priceChangePos = fin.changesPercentage != null && fin.changesPercentage >= 0;
    var priceColor = priceChangePos ? 'var(--color-green, #22c55e)' : 'var(--color-red, #ef4444)';
    var priceSign = priceChangePos ? '+' : '';
    // 52-week range fill %
    var wkRangeFill = 0;
    if (fin.yearHigh != null && fin.yearLow != null && fin.price != null && fin.yearHigh !== fin.yearLow) {
      wkRangeFill = Math.round(((fin.price - fin.yearLow) / (fin.yearHigh - fin.yearLow)) * 100);
      wkRangeFill = Math.min(100, Math.max(0, wkRangeFill));
    }
  %>
  <div class="drug-section" style="padding-bottom: 0;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 8px;">
      <h2 style="margin: 0;">
        Live Company Data
        <% if (fin.exchange) { %><span style="font-size: 12px; font-weight: 400; color: var(--text-muted); margin-left: 8px; text-transform: uppercase; letter-spacing: 0.05em;"><%= fin.exchange %></span><% } %>
      </h2>
      <span style="font-size: 11px; color: var(--text-muted);">
        Updated <% var fetchedMin = fin.fetchedAt ? Math.floor((Date.now() - new Date(fin.fetchedAt).getTime()) / 60000) : null; %>
        <% if (fetchedMin !== null) { %><%= fetchedMin < 1 ? 'just now' : fetchedMin + 'm ago' %><% } else { %>recently<% } %>
        · Data: <a href="https://financialmodelingprep.com" target="_blank" rel="nofollow noopener" style="color: var(--text-muted); text-decoration: underline;">FMP</a>
      </span>
    </div>

    <!-- Top row: Price + Market Cap -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
      <!-- Current Price -->
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 6px;">Current Price</div>
        <div style="display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;">
          <span style="font-size: 22px; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums;">
            <%= fin.price != null ? formatPrice(fin.price, fin.currency) : 'N/A' %>
          </span>
          <% if (fin.changesPercentage != null) { %>
          <span style="font-size: 13px; font-weight: 600; color: <%= priceColor %>;">
            <%= priceSign %><%= Number(fin.changesPercentage).toFixed(2) %>%
          </span>
          <% } %>
        </div>
        <% if (fin.change != null) { %>
        <div style="font-size: 12px; color: <%= priceColor %>; margin-top: 2px;">
          <%= priceSign %><%= formatPrice(fin.change, fin.currency) %> today
        </div>
        <% } %>
        <% if (fin.dayLow != null && fin.dayHigh != null) { %>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">
          Day: <%= formatPrice(fin.dayLow, fin.currency) %> – <%= formatPrice(fin.dayHigh, fin.currency) %>
        </div>
        <% } %>
      </div>

      <!-- Market Cap -->
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 6px;">Market Cap</div>
        <div style="font-size: 22px; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums;">
          <%= formatMarketCap(fin.marketCap) %>
        </div>
        <% if (fin.sharesOutstanding) { %>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 6px;">
          Shares out: <%= formatVolume(fin.sharesOutstanding) %>
        </div>
        <% } %>
        <% if (fin.floatShares) { %>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">
          Float: <%= formatVolume(fin.floatShares) %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- 52-Week Range -->
    <% if (fin.yearHigh != null && fin.yearLow != null) { %>
    <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; margin-bottom: 12px;">
      <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 10px;">52-Week Range</div>
      <div style="display: flex; align-items: center; gap: 10px;">
        <span style="font-size: 12px; color: var(--text-secondary); min-width: 48px; text-align: right; font-variant-numeric: tabular-nums;"><%= formatPrice(fin.yearLow, fin.currency) %></span>
        <div style="flex: 1; position: relative; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden;">
          <div style="position: absolute; left: 0; top: 0; height: 100%; width: <%= wkRangeFill %>%; background: var(--accent-teal); border-radius: 3px; transition: width 0.3s;"></div>
          <% if (fin.price != null) { %>
          <div style="position: absolute; top: 50%; left: <%= wkRangeFill %>%; transform: translate(-50%, -50%); width: 10px; height: 10px; background: var(--accent-teal); border-radius: 50%; border: 2px solid var(--bg-card);"></div>
          <% } %>
        </div>
        <span style="font-size: 12px; color: var(--text-secondary); min-width: 48px; font-variant-numeric: tabular-nums;"><%= formatPrice(fin.yearHigh, fin.currency) %></span>
      </div>
      <% if (fin.price != null) { %>
      <div style="font-size: 11px; color: var(--text-muted); margin-top: 6px; text-align: center;">
        Current price is at <strong style="color: var(--accent-teal);"><%= wkRangeFill %>%</strong> of 52-week range
      </div>
      <% } %>
    </div>
    <% } %>

    <!-- Bottom stats row: Volume, Beta, Sector/Industry -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 4px;">
      <% if (fin.avgVolume) { %>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 14px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 4px;">Avg Volume</div>
        <div style="font-size: 16px; font-weight: 600; color: var(--text-primary); font-variant-numeric: tabular-nums;"><%= formatVolume(fin.avgVolume) %></div>
      </div>
      <% } %>

      <% if (fin.beta != null) { %>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 14px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 4px;">Beta</div>
        <div style="font-size: 16px; font-weight: 600; color: var(--text-primary); font-variant-numeric: tabular-nums;"><%= Number(fin.beta).toFixed(2) %></div>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">vs. S&P 500</div>
      </div>
      <% } %>

      <% if (fin.sector) { %>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 14px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 4px;">Sector</div>
        <div style="font-size: 13px; font-weight: 600; color: var(--text-primary); line-height: 1.3;"><%= fin.sector %></div>
        <% if (fin.industry) { %>
        <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;"><%= fin.industry %></div>
        <% } %>
      </div>
      <% } %>
    </div>

    <div style="font-size: 11px; color: var(--text-muted); margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border);">
      ⚠️ Financial data is for informational purposes only. Not investment advice. Prices may be delayed.
    </div>
  </div>
  <% } else if (drug.ticker) { %>
  <!-- Client-side financial data (loaded from browser via Yahoo Finance public API) -->
  <div class="drug-section" id="fin-section" style="padding-bottom: 0;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 8px;">
      <h2 style="margin: 0;">Live Company Data</h2>
      <span id="fin-updated" style="font-size: 11px; color: var(--text-muted);"></span>
    </div>
    <div id="fin-content">
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; text-align: center; color: var(--text-muted); font-size: 13px;">
        <span id="fin-loading">Loading market data for <strong style="color: var(--accent-teal);"><%= drug.ticker %></strong>…</span>
      </div>
    </div>
  </div>
  <script>
  (function() {
    var ticker = '<%= drug.ticker.replace(/'/g, '') %>';
    var content = document.getElementById('fin-content');
    var updatedEl = document.getElementById('fin-updated');

    function fmt(n, d) { return (n != null && !isNaN(n)) ? Number(n).toFixed(d != null ? d : 2) : 'N/A'; }
    function fmtMC(n) {
      if (!n || isNaN(n)) return 'N/A';
      n = Number(n);
      if (n >= 1e12) return '$' + (n/1e12).toFixed(2) + 'T';
      if (n >= 1e9)  return '$' + (n/1e9).toFixed(2) + 'B';
      if (n >= 1e6)  return '$' + (n/1e6).toFixed(1) + 'M';
      return '$' + n.toLocaleString();
    }
    function fmtVol(n) {
      if (!n || isNaN(n)) return 'N/A';
      n = Number(n);
      if (n >= 1e9) return (n/1e9).toFixed(2) + 'B';
      if (n >= 1e6) return (n/1e6).toFixed(2) + 'M';
      if (n >= 1e3) return (n/1e3).toFixed(0) + 'K';
      return n.toLocaleString();
    }
    function cell(label, value, span) {
      var s = span ? 'grid-column:span 2;' : '';
      return '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;' + s + '">' +
        '<div style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-bottom:5px;">' + label + '</div>' +
        '<div style="font-size:16px;font-weight:700;color:var(--text-primary);">' + value + '</div></div>';
    }

    var url = 'https://query1.finance.yahoo.com/v8/finance/chart/' + encodeURIComponent(ticker) +
              '?range=1y&interval=1d&includePrePost=false';

    fetch(url, { headers: { 'Accept': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(raw) {
        var result = raw && raw.chart && raw.chart.result && raw.chart.result[0];
        if (!result) throw new Error('no data');

        var meta   = result.meta || {};
        var quotes = (result.indicators && result.indicators.quote && result.indicators.quote[0]) || {};

        var price   = meta.regularMarketPrice != null ? Number(meta.regularMarketPrice) : null;
        var prev    = meta.previousClose || meta.chartPreviousClose || meta.regularMarketPreviousClose;
        prev = prev != null ? Number(prev) : null;
        var change  = (price != null && prev != null) ? price - prev : null;
        var chgPct  = (change != null && prev > 0) ? change / prev * 100 : null;
        var mktCap  = meta.marketCap != null ? Number(meta.marketCap) : null;
        var vol     = meta.regularMarketVolume != null ? Number(meta.regularMarketVolume) : null;
        var avgVol  = meta.averageDailyVolume3Month || meta.averageDailyVolume10Day;
        avgVol = avgVol != null ? Number(avgVol) : null;
        var dayLo   = meta.regularMarketDayLow  != null ? Number(meta.regularMarketDayLow)  : null;
        var dayHi   = meta.regularMarketDayHigh != null ? Number(meta.regularMarketDayHigh) : null;

        var highs = (quotes.high || []).filter(function(v){ return v!=null; });
        var lows  = (quotes.low  || []).filter(function(v){ return v!=null; });
        var yrHi  = highs.length ? Math.max.apply(null,highs) : null;
        var yrLo  = lows.length  ? Math.min.apply(null,lows)  : null;

        var up  = chgPct != null && chgPct >= 0;
        var clr = up ? 'var(--color-green,#22c55e)' : 'var(--color-red,#ef4444)';
        var sgn = up ? '+' : '';

        // 52-week range bar fill %
        var fill = 0;
        if (yrHi!=null && yrLo!=null && price!=null && yrHi!==yrLo) {
          fill = Math.round(((price-yrLo)/(yrHi-yrLo))*100);
          fill = Math.min(100, Math.max(0, fill));
        }

        // Build price card
        var priceCard = '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;">' +
          '<div style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-bottom:6px;">Current Price</div>' +
          '<div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;">' +
            '<span style="font-size:22px;font-weight:700;color:var(--text-primary);">' + (price!=null ? '$'+fmt(price) : 'N/A') + '</span>' +
            (chgPct!=null ? '<span style="font-size:13px;font-weight:600;color:'+clr+';">' + sgn+fmt(chgPct)+'%</span>' : '') +
          '</div>' +
          (change!=null ? '<div style="font-size:12px;color:'+clr+';margin-top:2px;">' + sgn+'$'+fmt(Math.abs(change))+' today</div>' : '') +
          (dayLo!=null&&dayHi!=null ? '<div style="font-size:11px;color:var(--text-muted);margin-top:4px;">Day: $'+fmt(dayLo)+' – $'+fmt(dayHi)+'</div>' : '') +
        '</div>';

        var mcCard = '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;">' +
          '<div style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-bottom:6px;">Market Cap</div>' +
          '<div style="font-size:20px;font-weight:700;color:var(--text-primary);">' + fmtMC(mktCap) + '</div>' +
        '</div>';

        var rangeCard = '';
        if (yrHi!=null && yrLo!=null) {
          rangeCard = '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;grid-column:span 2;">' +
            '<div style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);margin-bottom:8px;">52-Week Range</div>' +
            '<div style="display:flex;align-items:center;gap:10px;">' +
              '<span style="font-size:12px;color:var(--text-muted);">$'+fmt(yrLo)+'</span>' +
              '<div style="flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden;">' +
                '<div style="height:100%;width:'+fill+'%;background:var(--accent-teal,#2dd4bf);border-radius:3px;transition:width .4s;"></div>' +
              '</div>' +
              '<span style="font-size:12px;color:var(--text-muted);">$'+fmt(yrHi)+'</span>' +
            '</div>' +
          '</div>';
        }

        var statsRow = '';
        if (vol!=null || avgVol!=null) {
          statsRow = (vol!=null ? cell('Volume', fmtVol(vol)) : '') + (avgVol!=null ? cell('Avg Volume', fmtVol(avgVol)) : '');
        }

        content.innerHTML =
          '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:0;">' +
            priceCard + mcCard + rangeCard + statsRow +
          '</div>' +
          '<div style="font-size:11px;color:var(--text-muted);margin-top:10px;padding-top:10px;border-top:1px solid var(--border);">' +
            '⚠️ Financial data is for informational purposes only. Not investment advice. Prices may be delayed. Source: Yahoo Finance.' +
          '</div>';

        if (updatedEl) updatedEl.textContent = 'Updated just now · Yahoo Finance';
      })
      .catch(function() {
        content.innerHTML = '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;color:var(--text-muted);font-size:13px;">Financial data for <strong style="color:var(--accent-teal);">' + ticker + '</strong> is temporarily unavailable.</div>';
      });
  })();
  </script>
  <% } %>

  <!-- Substack CTA: track this catalyst -->
  <div class="drug-newsletter-cta">
    <span>Track <%= drug.cashtag ? drug.cashtag : (drug.ticker ? '$' + drug.ticker : drug.drug_name) %> catalysts → get weekly FDA alerts</span>
    <a href="<%= appBase %>/go/substack?p=drug_inline" target="_blank" rel="noopener">Subscribe Free on Substack →</a>
  </div>

  <!-- Indication -->
  <div class="drug-section">
    <h2>Indication</h2>
    <div class="drug-indication-text"><%= drug.indication %></div>
  </div>

  <!-- Key Notes -->
  <% if (drug.notes) { %>
  <div class="drug-section">
    <h2>Key Notes</h2>
    <div class="drug-notes"><%= drug.notes %></div>
  </div>
  <% } %>

  <!-- Dan's DD Articles (if any) -->
  <% if (articles && articles.length > 0) { %>
  <div class="drug-section">
    <h2>Dan's Due Diligence</h2>
    <% articles.forEach(function(a) { %>
    <div style="padding: 12px 0; border-bottom: 1px solid var(--border);">
      <a href="<%= typeof appBase !== 'undefined' ? appBase : '' %>/article/<%= a.slug %>" style="font-size: 15px; font-weight: 600; color: var(--text-primary);">
        <%= a.title %>
      </a>
      <% if (a.excerpt) { %>
      <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;"><%= a.excerpt %></div>
      <% } %>
      <div style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">
        <%= new Date(a.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Disclaimer -->
  <div class="disclaimer-box">
    <strong>⚠️ Not Investment Advice:</strong> This information is provided for educational purposes only.
    PDUFA dates are FDA target action dates, not guaranteed approval dates. The FDA may extend the review period,
    issue Complete Response Letters, or take unexpected actions. Probability of approval scores are based on
    historical base rates and do not account for drug-specific factors. Always consult a financial advisor
    before making investment decisions.
  </div>

  <!-- Discussion Threads -->
  <div class="drug-section" id="discussion">
    <h2>Discussion</h2>
    <p style="font-size: 13px; color: var(--text-muted); margin: 0 0 20px;">
      Share your analysis, research, or questions about this catalyst. No account required.
    </p>

    <!-- Comment Form -->
    <div class="comment-form-wrap" id="comment-form-wrap">
      <form id="comment-form" onsubmit="submitComment(event)">
        <div class="comment-form-fields" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
          <div>
            <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 4px;">Display Name <span style="color: var(--color-red);">*</span></label>
            <input type="text" id="comment-name" placeholder="e.g. BiotechInvestor42" maxlength="50" required
              style="width: 100%; padding: 9px 12px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-primary); font-size: 13px; box-sizing: border-box;">
          </div>
          <div>
            <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 4px;">Email (not shown) <span style="color: var(--color-red);">*</span></label>
            <input type="email" id="comment-email" placeholder="your@email.com" required
              style="width: 100%; padding: 9px 12px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-primary); font-size: 13px; box-sizing: border-box;">
          </div>
        </div>
        <div style="margin-bottom: 12px;">
          <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 4px;">Comment <span style="color: var(--color-red);">*</span></label>
          <textarea id="comment-text" placeholder="Your analysis, questions, or thoughts..." maxlength="2000" rows="4" required
            style="width: 100%; padding: 9px 12px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-primary); font-size: 13px; resize: vertical; box-sizing: border-box;"></textarea>
        </div>
        <div id="comment-error" style="display:none; color: var(--color-red); font-size: 13px; margin-bottom: 10px;"></div>
        <button type="submit" id="comment-submit"
          style="background: var(--accent-teal); color: #000; padding: 9px 20px; border: none; border-radius: var(--radius); font-size: 13px; font-weight: 600; cursor: pointer;">
          Post Comment
        </button>
        <span style="font-size: 11px; color: var(--text-muted); margin-left: 12px;">Rate limit: 5/hr per email</span>
      </form>
    </div>

    <!-- Comments List -->
    <div id="comments-list" style="margin-top: 24px;">
      <div style="color: var(--text-muted); font-size: 13px;">Loading comments...</div>
    </div>
    <div id="comments-load-more" style="display: none; text-align: center; margin-top: 16px;">
      <button onclick="loadComments(currentPage + 1)"
        style="background: transparent; border: 1px solid var(--border); color: var(--text-secondary); padding: 8px 16px; border-radius: var(--radius); font-size: 13px; cursor: pointer;">
        Load More
      </button>
    </div>
  </div>

  <script>
  (function() {
    var SLUG = '<%= drug.slug.replace(/'/g, "\\'") %>';
    var BASE = '<%= (typeof appBase !== "undefined" ? appBase : "") %>';
    var currentPage = 1;
    var totalComments = 0;

    function timeAgo(dateStr) {
      var d = new Date(dateStr);
      var now = new Date();
      var diff = Math.floor((now - d) / 1000);
      if (diff < 60) return diff + 's ago';
      if (diff < 3600) return Math.floor(diff/60) + 'm ago';
      if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
      return Math.floor(diff/86400) + 'd ago';
    }

    function renderComments(comments, append) {
      var list = document.getElementById('comments-list');
      if (!append) list.innerHTML = '';

      if (comments.length === 0 && !append) {
        list.innerHTML = '<div style="text-align:center;padding:32px 0;color:var(--text-muted);font-size:13px;">No comments yet — be the first to share your analysis.</div>';
        return;
      }

      comments.forEach(function(c) {
        var el = document.createElement('div');
        el.style.cssText = 'padding: 14px 0; border-bottom: 1px solid var(--border);';
        el.innerHTML = '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">' +
          '<div style="width:32px;height:32px;border-radius:50%;background:var(--accent-teal-dim);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--accent-teal);">' +
            c.display_name.charAt(0).toUpperCase() +
          '</div>' +
          '<div>' +
            '<div style="font-size:13px;font-weight:600;color:var(--text-primary);">' + c.display_name + '</div>' +
            '<div style="font-size:11px;color:var(--text-muted);">' + timeAgo(c.created_at) + '</div>' +
          '</div></div>' +
          '<div style="font-size:13px;color:var(--text-secondary);line-height:1.6;white-space:pre-wrap;">' + c.text.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</div>';
        list.appendChild(el);
      });
    }

    window.loadComments = function(page) {
      currentPage = page || 1;
      fetch(BASE + '/api/comments/' + SLUG + '?page=' + currentPage)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            totalComments = data.total;
            renderComments(data.comments, currentPage > 1);
            var loadMore = document.getElementById('comments-load-more');
            if (data.total > currentPage * data.limit) {
              loadMore.style.display = 'block';
            } else {
              loadMore.style.display = 'none';
            }
          } else {
            document.getElementById('comments-list').innerHTML = '<div style="color:var(--text-muted);font-size:13px;">Could not load comments.</div>';
          }
        })
        .catch(function() {
          document.getElementById('comments-list').innerHTML = '<div style="color:var(--text-muted);font-size:13px;">Could not load comments.</div>';
        });
    };

    window.submitComment = function(e) {
      e.preventDefault();
      var name = document.getElementById('comment-name').value.trim();
      var email = document.getElementById('comment-email').value.trim();
      var text = document.getElementById('comment-text').value.trim();
      var errEl = document.getElementById('comment-error');
      var btn = document.getElementById('comment-submit');

      errEl.style.display = 'none';
      btn.disabled = true;
      btn.textContent = 'Posting...';

      fetch(BASE + '/api/comments/' + SLUG, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ display_name: name, email: email, text: text })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        btn.disabled = false;
        btn.textContent = 'Post Comment';
        if (data.success) {
          document.getElementById('comment-name').value = '';
          document.getElementById('comment-email').value = '';
          document.getElementById('comment-text').value = '';
          // Reload comments from top
          loadComments(1);
        } else {
          errEl.textContent = data.message || 'Failed to post comment.';
          errEl.style.display = 'block';
        }
      })
      .catch(function() {
        btn.disabled = false;
        btn.textContent = 'Post Comment';
        errEl.textContent = 'Network error. Please try again.';
        errEl.style.display = 'block';
      });
    };

    // Load comments on page load
    loadComments(1);
  })();
  </script>

  <!-- Back to calendar -->
  <div style="margin-top: 24px; text-align: center;">
    <a href="<%= typeof appBase !== 'undefined' ? appBase : '' %>/" class="btn btn-primary">← Back to Full Calendar</a>
  </div>

  <!-- Adsterra in-content ad -->
  <%- include('../partials/ad-adsterra') %>

</div>

<script>
// Analytics: backup CTA click tracking (primary tracking is via /go/substack redirect)
function trackCtaClick(placement) {
  try {
    var payload = JSON.stringify({
      event_type: 'cta_click',
      placement: placement,
      page: window.location.pathname
    });
    if (navigator.sendBeacon) {
      var blob = new Blob([payload], { type: 'application/json' });
      navigator.sendBeacon('/api/evt', blob);
    } else {
      fetch('/api/evt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: payload,
        keepalive: true
      }).catch(function() {});
    }
  } catch(e) {}
}
</script>

<%- include('../partials/footer') %>
