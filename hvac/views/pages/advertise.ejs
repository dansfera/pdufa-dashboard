<%- include('../partials/header') %>

<!-- Page Header -->
<div class="text-white py-12" style="background: linear-gradient(to right, #7c3aed, #6d28d9);">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div class="text-4xl mb-3">🌡️</div>
    <h1 class="text-3xl sm:text-4xl font-bold font-heading mb-3">Advertise With Us</h1>
    <p class="text-purple-200 text-lg max-w-2xl mx-auto">Reach homeowners actively searching for HVAC repair and AC services in the Sunbelt. Your business, in front of the right audience — at the exact moment they need help.</p>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

  <!-- Audience Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold font-heading text-slate-800 mb-4">Our Audience</h2>
    <p class="text-gray-600 mb-6 leading-relaxed">Sunbelt HVAC Guide attracts local homeowners dealing with broken AC units, heating failures, and HVAC maintenance needs. In the Sunbelt's extreme heat, a broken AC isn't an inconvenience — it's an emergency. These visitors are ready to hire.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
      <div class="bg-purple-50 border border-purple-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-purple-700 mb-1">5</div>
        <div class="text-sm text-slate-600 font-medium">Sunbelt Cities Covered</div>
        <div class="text-xs text-slate-500 mt-1">Yuma, Tucson, Tulsa, Greenville, Kansas City</div>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-purple-700 mb-1">21+</div>
        <div class="text-sm text-slate-600 font-medium">Informational Pages</div>
        <div class="text-xs text-slate-500 mt-1">City guides, service pages &amp; HVAC articles</div>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-xl p-5 text-center">
        <div class="text-3xl font-bold text-purple-700 mb-1">115°F+</div>
        <div class="text-sm text-slate-600 font-medium">Sunbelt Summer Heat</div>
        <div class="text-xs text-slate-500 mt-1">Yuma, Tucson &amp; Tulsa hit extreme temps — AC demand is year-round</div>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-6">
      <h3 class="font-semibold text-slate-800 mb-3">Cities We Reach</h3>
      <div class="flex flex-wrap gap-2">
        <% cities.forEach(function(c) { %>
          <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-sm"><%= c.fullName %></span>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Ad Options Section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold font-heading text-slate-800 mb-4">Advertising Options</h2>
    <p class="text-gray-600 mb-6">Flexible placements that get your HVAC business in front of local homeowners the moment their AC dies.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">

      <div class="bg-white border border-slate-200 rounded-xl p-6 hover:border-purple-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-3">🏷️</div>
        <h3 class="font-bold text-slate-800 text-lg mb-2">Banner Ads</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Display ads placed throughout city pages and HVAC guides. Standard IAB sizes, mobile-optimized for on-the-go homeowners.</p>
        <ul class="mt-3 space-y-1 text-sm text-slate-600">
          <li>✓ Header &amp; sidebar placements</li>
          <li>✓ In-content placements</li>
          <li>✓ Mobile-optimized</li>
        </ul>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-6 hover:border-purple-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-3">⭐</div>
        <h3 class="font-bold text-slate-800 text-lg mb-2">Sponsored Listings</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Featured as a recommended HVAC provider on city and service pages. Your name, description, and contact link included.</p>
        <ul class="mt-3 space-y-1 text-sm text-slate-600">
          <li>✓ City-specific pages</li>
          <li>✓ Service category pages</li>
          <li>✓ Clearly labeled as sponsored</li>
        </ul>
      </div>

      <div class="bg-white border border-purple-300 rounded-xl p-6 shadow-sm relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-purple-600 text-white text-xs font-semibold px-3 py-1 rounded-full">Most Popular</div>
        <div class="text-3xl mb-3">🔝</div>
        <h3 class="font-bold text-slate-800 text-lg mb-2">Featured Placement</h3>
        <p class="text-gray-600 text-sm leading-relaxed">Top-of-page position on city landing pages and service guides. Maximum visibility in the markets you serve.</p>
        <ul class="mt-3 space-y-1 text-sm text-slate-600">
          <li>✓ Above-the-fold placement</li>
          <li>✓ Target specific cities</li>
          <li>✓ Logo + description + CTA</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Why Advertise Section -->
  <section class="mb-12">
    <div class="bg-slate-800 text-white rounded-2xl p-8">
      <h2 class="text-2xl font-bold font-heading mb-4">Why Advertise on Sunbelt HVAC Guide?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <span class="text-purple-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Extreme-Heat Market</div>
            <div class="text-slate-300 text-sm">Sunbelt cities see peak AC demand from March through October. These homeowners can't wait — they call the first trusted business they find.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-purple-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">High-Value Jobs</div>
            <div class="text-slate-300 text-sm">AC replacements average $4,000–$8,000. A single job from one ad placement covers months of advertising investment.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-purple-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Local &amp; Targeted</div>
            <div class="text-slate-300 text-sm">Every visitor is in a specific Sunbelt city you can target. No wasted impressions on out-of-area homeowners.</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-purple-400 text-xl mt-0.5">✓</span>
          <div>
            <div class="font-semibold mb-1">Direct Relationship</div>
            <div class="text-slate-300 text-sm">No lead aggregators, no shared leads. Your ad, your brand, your calls.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="contact">
    <h2 class="text-2xl font-bold font-heading text-slate-800 mb-2">Get In Touch</h2>
    <p class="text-gray-600 mb-6">Fill out the form below and we'll get back to you within 1-2 business days with pricing and availability.</p>

    <% if (typeof formSuccess !== 'undefined' && formSuccess) { %>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6 text-center mb-6">
        <div class="text-4xl mb-2">✅</div>
        <h3 class="text-lg font-semibold text-green-800 mb-1">Message Sent!</h3>
        <p class="text-green-700 text-sm">Thanks for reaching out. We'll get back to you within 1-2 business days.</p>
      </div>
    <% } else if (typeof formError !== 'undefined' && formError) { %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
        <p class="text-red-700 text-sm"><%= formError %></p>
      </div>
    <% } %>

    <% if (typeof formSuccess === 'undefined' || !formSuccess) { %>
    <form action="/hvac/advertise" method="POST" class="bg-white border border-slate-200 rounded-2xl p-6 sm:p-8 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="name">Your Name <span class="text-red-500">*</span></label>
          <input type="text" id="name" name="name" required placeholder="Jane Smith"
            class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition-all"
            value="<%= typeof formValues !== 'undefined' ? formValues.name : '' %>">
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="business_name">Business Name <span class="text-red-500">*</span></label>
          <input type="text" id="business_name" name="business_name" required placeholder="Acme HVAC Services"
            class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition-all"
            value="<%= typeof formValues !== 'undefined' ? formValues.business_name : '' %>">
        </div>
      </div>
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="email">Email Address <span class="text-red-500">*</span></label>
        <input type="email" id="email" name="email" required placeholder="jane@acmehvac.com"
          class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition-all"
          value="<%= typeof formValues !== 'undefined' ? formValues.email : '' %>">
      </div>
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="message">Tell Us About Your Business <span class="text-red-500">*</span></label>
        <textarea id="message" name="message" required rows="4" placeholder="Which cities do you serve? What HVAC services do you offer? What kind of advertising are you interested in?"
          class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent transition-all resize-none"><%= typeof formValues !== 'undefined' ? formValues.message : '' %></textarea>
      </div>
      <button type="submit"
        class="w-full sm:w-auto bg-purple-600 hover:bg-purple-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors text-sm shadow-sm hover:shadow">
        Send Inquiry &rarr;
      </button>
    </form>
    <% } %>
  </section>

</div>

<%- include('../partials/footer') %>
