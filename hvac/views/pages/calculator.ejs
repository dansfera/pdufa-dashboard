<%- include('../partials/header', { title, metaDescription, canonicalUrl, cities, services, analyticsSlug, baseUrl }) %>

  <!-- Page Hero -->
  <section class="bg-gradient-to-br from-hvac-700 via-hvac-800 to-slate-900 text-white py-12 md:py-16" style="background:linear-gradient(to bottom right,#c2410c,#9a3412,#0f172a)">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="text-4xl mb-4">🧮</div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4 font-heading">Free HVAC Sizing Calculator</h1>
      <p class="text-lg text-hvac-100 max-w-2xl mx-auto">
        Get an instant estimate for the right AC unit size and installation cost — tailored to your Sunbelt city, home size, and insulation.
      </p>
    </div>
  </section>

  <!-- Calculator + Results -->
  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

        <!-- LEFT: Calculator Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="bg-slate-50 border-b border-slate-200 px-6 py-4">
              <h2 class="text-lg font-bold text-slate-800">Enter Your Home Details</h2>
              <p class="text-sm text-slate-500 mt-0.5">All fields adjust the recommendation — takes about 30 seconds</p>
            </div>

            <div class="p-6 space-y-6">

              <!-- Square Footage -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                  Home Square Footage
                  <span class="text-hvac-600 font-bold ml-2" id="sqft-display">1,500 sq ft</span>
                </label>
                <input
                  type="range"
                  id="sqft-slider"
                  min="500" max="5000" step="100" value="1500"
                  class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-hvac-600"
                  oninput="updateSqft(this.value)"
                />
                <div class="flex justify-between text-xs text-slate-400 mt-1">
                  <span>500 sq ft</span>
                  <span>2,500</span>
                  <span>5,000 sq ft</span>
                </div>
                <!-- Quick Select -->
                <div class="flex flex-wrap gap-2 mt-3">
                  <button onclick="setSqft(800)" class="sqft-btn text-xs px-3 py-1.5 rounded-full border border-slate-300 text-slate-600 hover:border-hvac-500 hover:text-hvac-700 hover:bg-hvac-50 transition-colors">Small (&lt;1,000)</button>
                  <button onclick="setSqft(1500)" class="sqft-btn text-xs px-3 py-1.5 rounded-full border border-slate-300 text-slate-600 hover:border-hvac-500 hover:text-hvac-700 hover:bg-hvac-50 transition-colors">Medium (1,000–2,000)</button>
                  <button onclick="setSqft(2500)" class="sqft-btn text-xs px-3 py-1.5 rounded-full border border-slate-300 text-slate-600 hover:border-hvac-500 hover:text-hvac-700 hover:bg-hvac-50 transition-colors">Large (2,000–3,000)</button>
                  <button onclick="setSqft(4000)" class="sqft-btn text-xs px-3 py-1.5 rounded-full border border-slate-300 text-slate-600 hover:border-hvac-500 hover:text-hvac-700 hover:bg-hvac-50 transition-colors">XL (3,000+)</button>
                </div>
              </div>

              <!-- City / Climate Zone -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Your City / Climate Zone</label>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  <% const cityOptions = [
                    { slug: 'yuma', label: 'Yuma, AZ', desc: 'Extreme desert heat', emoji: '🌵' },
                    { slug: 'tucson', label: 'Tucson, AZ', desc: 'Hot & dry desert', emoji: '🌵' },
                    { slug: 'tulsa', label: 'Tulsa, OK', desc: 'Hot humid summers', emoji: '🌪️' },
                    { slug: 'greenville', label: 'Greenville, SC', desc: 'Hot & humid', emoji: '🌿' },
                    { slug: 'kansas-city', label: 'Kansas City, MO', desc: 'Hot summers, cold winters', emoji: '🌾' }
                  ]; %>
                  <% cityOptions.forEach(c => { %>
                    <label class="city-option flex items-start gap-3 p-3 rounded-xl border border-slate-200 cursor-pointer hover:border-hvac-400 hover:bg-hvac-50 transition-all has-[:checked]:border-hvac-500 has-[:checked]:bg-hvac-50 has-[:checked]:ring-1 has-[:checked]:ring-hvac-400">
                      <input type="radio" name="city" value="<%= c.slug %>" class="mt-0.5 accent-hvac-600" <%= c.slug === 'tulsa' ? 'checked' : '' %> onchange="calcResult()"/>
                      <div>
                        <div class="font-semibold text-slate-800 text-sm"><%= c.emoji %> <%= c.label %></div>
                        <div class="text-xs text-slate-500"><%= c.desc %></div>
                      </div>
                    </label>
                  <% }); %>
                </div>
              </div>

              <!-- Insulation Quality -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Insulation Quality</label>
                <div class="grid grid-cols-3 gap-3">
                  <label class="insulation-option flex flex-col items-center gap-2 p-3 rounded-xl border border-slate-200 cursor-pointer hover:border-hvac-400 hover:bg-hvac-50 transition-all has-[:checked]:border-hvac-500 has-[:checked]:bg-hvac-50 has-[:checked]:ring-1 has-[:checked]:ring-hvac-400 text-center">
                    <input type="radio" name="insulation" value="poor" class="accent-hvac-600" onchange="calcResult()"/>
                    <span class="text-2xl">🥵</span>
                    <div>
                      <div class="font-semibold text-slate-800 text-sm">Poor</div>
                      <div class="text-xs text-slate-500">Older home, drafts, minimal attic insulation</div>
                    </div>
                  </label>
                  <label class="insulation-option flex flex-col items-center gap-2 p-3 rounded-xl border border-slate-200 cursor-pointer hover:border-hvac-400 hover:bg-hvac-50 transition-all has-[:checked]:border-hvac-500 has-[:checked]:bg-hvac-50 has-[:checked]:ring-1 has-[:checked]:ring-hvac-400 text-center">
                    <input type="radio" name="insulation" value="average" class="accent-hvac-600" checked onchange="calcResult()"/>
                    <span class="text-2xl">🏠</span>
                    <div>
                      <div class="font-semibold text-slate-800 text-sm">Average</div>
                      <div class="text-xs text-slate-500">Standard construction, typical insulation</div>
                    </div>
                  </label>
                  <label class="insulation-option flex flex-col items-center gap-2 p-3 rounded-xl border border-slate-200 cursor-pointer hover:border-hvac-400 hover:bg-hvac-50 transition-all has-[:checked]:border-hvac-500 has-[:checked]:bg-hvac-50 has-[:checked]:ring-1 has-[:checked]:ring-hvac-400 text-center">
                    <input type="radio" name="insulation" value="good" class="accent-hvac-600" onchange="calcResult()"/>
                    <span class="text-2xl">❄️</span>
                    <div>
                      <div class="font-semibold text-slate-800 text-sm">Good</div>
                      <div class="text-xs text-slate-500">Energy-efficient windows, well-insulated attic</div>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Stories -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Number of Stories</label>
                <div class="flex gap-3">
                  <% [1,2,3].forEach(n => { %>
                    <label class="story-option flex-1 flex flex-col items-center gap-1.5 p-3 rounded-xl border border-slate-200 cursor-pointer hover:border-hvac-400 hover:bg-hvac-50 transition-all has-[:checked]:border-hvac-500 has-[:checked]:bg-hvac-50 has-[:checked]:ring-1 has-[:checked]:ring-hvac-400 text-center">
                      <input type="radio" name="stories" value="<%= n %>" class="accent-hvac-600" <%= n === 1 ? 'checked' : '' %> onchange="calcResult()"/>
                      <span class="text-xl"><%= n === 1 ? '🏡' : n === 2 ? '🏘️' : '🏢' %></span>
                      <span class="font-semibold text-slate-800 text-sm"><%= n %> <%= n === 1 ? 'Story' : 'Stories' %></span>
                    </label>
                  <% }); %>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- RIGHT: Results -->
        <div class="lg:col-span-2">
          <div id="results-panel" class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden sticky top-24">

            <!-- Result Header -->
            <div class="bg-gradient-to-br from-hvac-600 to-hvac-800 text-white px-6 py-5" style="background:linear-gradient(to bottom right,#ea580c,#9a3412)">
              <div class="text-sm font-medium text-hvac-200 mb-1">Your Recommendation</div>
              <div class="flex items-end gap-2">
                <span id="result-tons" class="text-5xl font-bold">2.5</span>
                <span class="text-xl font-semibold text-hvac-200 mb-1.5">tons</span>
              </div>
              <div id="result-btu" class="text-hvac-200 text-sm mt-1">30,000 BTU/hr</div>
            </div>

            <!-- Result Details -->
            <div class="p-5 space-y-4">

              <!-- Tonnage Range -->
              <div class="bg-hvac-50 rounded-xl p-4 border border-hvac-100">
                <div class="text-xs font-semibold uppercase tracking-wider text-hvac-700 mb-1">Recommended Size Range</div>
                <div id="result-range" class="text-xl font-bold text-hvac-800">2.0 – 3.0 tons</div>
                <div class="text-xs text-slate-500 mt-1">Based on Manual J simplified formula</div>
              </div>

              <!-- Cost Estimate -->
              <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                <div class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Estimated Installation Cost</div>
                <div id="result-cost" class="text-xl font-bold text-slate-800">$4,750 – $7,000</div>
                <div class="text-xs text-slate-500 mt-1">Includes equipment + labor in your city</div>
              </div>

              <!-- Breakdown -->
              <div class="space-y-2">
                <div class="flex justify-between text-sm">
                  <span class="text-slate-600">Base BTU (sq ft × 25)</span>
                  <span id="result-base-btu" class="font-medium text-slate-800">37,500</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-slate-600">Climate adjustment</span>
                  <span id="result-climate-adj" class="font-medium text-hvac-700">+15%</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-slate-600">Insulation adjustment</span>
                  <span id="result-insulation-adj" class="font-medium text-slate-800">0%</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-slate-600">Stories adjustment</span>
                  <span id="result-stories-adj" class="font-medium text-slate-800">0%</span>
                </div>
                <div class="border-t border-slate-200 pt-2 flex justify-between text-sm font-semibold">
                  <span class="text-slate-700">Final BTU load</span>
                  <span id="result-final-btu" class="text-slate-900">43,125</span>
                </div>
              </div>

              <!-- Disclaimer -->
              <p class="text-xs text-slate-400 leading-relaxed">
                This estimate uses a simplified Manual J formula. Actual sizing requires an in-home load calculation by a licensed HVAC tech. Costs reflect 2025–2026 Sunbelt market averages.
              </p>

              <!-- CTA -->
              <a href="/hvac/services/ac-installation/" class="block w-full text-center bg-hvac-600 hover:bg-hvac-700 text-white font-semibold py-3 rounded-xl transition-colors text-sm">
                Learn About AC Installation &rarr;
              </a>
            </div>
          </div>
        </div>

      </div><!-- /grid -->
    </div>
  </section>

  <%- include('../partials/ad-inline') %>

  <!-- How the Calculator Works -->
  <section class="py-12 bg-white border-t border-slate-200">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-800 mb-3 font-heading">How the Calculator Works</h2>
      <p class="text-gray-600 mb-8 max-w-2xl">Our calculator uses a simplified version of Manual J — the industry-standard HVAC sizing methodology. Here's what each factor means for your system.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
          <div class="text-2xl mb-3">📐</div>
          <h3 class="font-semibold text-slate-800 mb-2">Square Footage</h3>
          <p class="text-gray-600 text-sm">The base rule of thumb: roughly 1 ton of cooling capacity per 600 sq ft, or 25 BTU per square foot. Larger homes need proportionally larger systems, but not always linearly — layout and ceiling height matter too.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
          <div class="text-2xl mb-3">🌡️</div>
          <h3 class="font-semibold text-slate-800 mb-2">Climate Zone</h3>
          <p class="text-gray-600 text-sm">Extreme heat cities like Yuma (summer highs 110°F+) require 20–25% more cooling capacity than national averages. Kansas City, with more moderate summers, requires a smaller upsize. Climate is the single biggest variable in Sunbelt sizing.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
          <div class="text-2xl mb-3">🏚️</div>
          <h3 class="font-semibold text-slate-800 mb-2">Insulation Quality</h3>
          <p class="text-gray-600 text-sm">Poor insulation (older homes, single-pane windows, no attic insulation) can increase the cooling load by 15%+. Good insulation (spray foam, double-pane windows, R-38 attic) can reduce the required tonnage by 10%, saving on equipment cost.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
          <div class="text-2xl mb-3">🏗️</div>
          <h3 class="font-semibold text-slate-800 mb-2">Number of Stories</h3>
          <p class="text-gray-600 text-sm">Multi-story homes have more exterior wall surface area relative to square footage, which increases heat gain. A 3-story home adds roughly 10% to the cooling load versus a single-story home of the same square footage.</p>
        </div>
      </div>
    </div>
  </section>

