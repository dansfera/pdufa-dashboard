<%- include('../partials/header', { title, metaDescription, canonicalUrl, cities, services, analyticsSlug, baseUrl }) %>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-hvac-700 via-hvac-800 to-slate-900 text-white py-16 md:py-24" style="background:linear-gradient(to bottom right,#c2410c,#9a3412,#0f172a)">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight font-heading">
        Your Complete <span class="text-hvac-300">Sunbelt</span> HVAC & AC Repair Guide
      </h1>
      <p class="text-xl md:text-2xl text-hvac-100 max-w-3xl mx-auto mb-10">
        Expert HVAC information for homeowners across the Sunbelt region. Local cost guides, seasonal maintenance tips, and honest repair-vs-replace advice — no contractor referrals, just answers.
      </p>

      <!-- City Selector -->
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <% cities.forEach(c => { %>
          <a href="/hvac/<%= c.slug %>/" class="px-5 py-2.5 bg-white/10 hover:bg-hvac-500 hover:text-white rounded-full text-white font-medium transition-all duration-200 backdrop-blur-sm border border-white/20 hover:border-hvac-500">
            <%= c.fullName %>
          </a>
        <% }) %>
      </div>
      <p class="text-hvac-300 text-sm">5 cities covered &bull; 9 service categories &bull; <a href="/hvac/calculator" class="underline hover:text-white transition-colors">Free sizing calculator</a> &bull; Updated for 2026</p>
    </div>
  </section>

  <!-- Heat Emergency Banner -->
  <div class="bg-red-600 text-white py-3 px-4 text-center text-sm font-medium">
    🌡️ <strong>AC out in extreme heat?</strong> Don't wait — call an HVAC company immediately. AC failure above 90°F indoors is a health emergency.
  </div>

  <!-- HVAC Calculator CTA -->
  <section class="py-10 md:py-12 bg-gradient-to-r from-sky-50 to-hvac-50 border-b border-sky-100">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10">
        <div class="text-5xl md:text-6xl shrink-0">🧮</div>
        <div class="flex-1 text-center md:text-left">
          <div class="text-xs font-bold uppercase tracking-widest text-hvac-600 mb-1">Free Tool</div>
          <h2 class="text-xl md:text-2xl font-bold text-slate-800 font-heading mb-2">What Size HVAC Do You Actually Need?</h2>
          <p class="text-gray-600 text-sm md:text-base max-w-lg">Enter your home size, city, and insulation level — get an instant tonnage recommendation and installation cost range. No email required.</p>
        </div>
        <div class="shrink-0">
          <a href="/hvac/calculator" class="inline-flex items-center gap-2 bg-hvac-600 hover:bg-hvac-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors shadow-sm text-sm md:text-base whitespace-nowrap">
            Use the Calculator &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-800 mb-8 font-heading">Latest HVAC Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% articles.slice(0, 5).forEach(a => { %>
          <% const articleCity = cities.find(c => c.slug === a.city); %>
          <article class="bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:border-slate-300 transition-all duration-200 overflow-hidden group relative">
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-hvac-600 bg-hvac-50 px-2 py-0.5 rounded-full">
                  <%= articleCity ? articleCity.fullName : '' %>
                </span>
                <span class="text-xs text-gray-400"><%= a.readTime %></span>
              </div>
              <h3 class="font-bold text-lg text-slate-800 group-hover:text-hvac-700 transition-colors mb-2 line-clamp-2">
                <a href="/hvac/<%= a.city %>/<%= a.slug %>/" class="after:absolute after:inset-0 relative">
                  <%= a.title %>
                </a>
              </h3>
              <p class="text-gray-600 text-sm line-clamp-3"><%= a.excerpt %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('../partials/ad-inline') %>

  <!-- Cities Section -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-800 mb-3 font-heading">Browse by City</h2>
      <p class="text-gray-600 mb-8 max-w-2xl">Get HVAC information specific to your area — local climate challenges, typical costs, seasonal timing, and what systems work best in your city's weather.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% cities.forEach(c => { %>
          <a href="/hvac/<%= c.slug %>/" class="block bg-slate-50 rounded-xl p-6 hover:bg-hvac-50 border border-slate-200 hover:border-hvac-300 transition-all group">
            <h3 class="text-xl font-bold text-slate-800 group-hover:text-hvac-700 mb-2"><%= c.fullName %></h3>
            <p class="text-gray-600 text-sm mb-3"><%= c.climate %></p>
            <p class="text-sm font-semibold text-hvac-600 mb-3"><%= c.avgHvacCost %></p>
            <div class="flex flex-wrap gap-1.5">
              <% c.topServices.slice(0, 3).forEach(svc => { %>
                <span class="text-xs bg-slate-200 text-slate-700 px-2 py-0.5 rounded-full"><%= svc.replace(/-/g, ' ') %></span>
              <% }) %>
            </div>
            <p class="text-hvac-600 text-sm font-medium mt-3 group-hover:text-hvac-700">View local guide &rarr;</p>
          </a>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('../partials/ad-adsterra') %>

  <!-- Services Section -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-800 mb-3 font-heading">Browse by Service Type</h2>
      <p class="text-gray-600 mb-8 max-w-2xl">Learn about specific HVAC services — what's involved, typical costs, warning signs, and how to find a reputable contractor in your area.</p>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4">
        <% services.forEach(s => { %>
          <a href="/hvac/services/<%= s.slug %>/" class="block bg-white rounded-xl p-5 hover:shadow-md border border-slate-200 hover:border-hvac-300 transition-all group">
            <span class="text-3xl block mb-2"><%= s.icon %></span>
            <h3 class="font-semibold text-slate-800 group-hover:text-hvac-700 text-sm leading-tight"><%= s.name %></h3>
            <p class="text-xs text-gray-500 mt-1"><%= s.shortDesc %></p>
            <p class="text-xs text-hvac-600 font-medium mt-2"><%= s.avgCost %></p>
          </a>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="py-12 bg-slate-100 border-t border-slate-200">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-slate-800 mb-4 font-heading">Why Trust Sunbelt HVAC Guide?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <div class="p-4">
          <div class="text-3xl mb-3">📊</div>
          <h3 class="font-semibold text-slate-800 mb-2">Real Local Cost Data</h3>
          <p class="text-gray-600 text-sm">Our cost guides are based on real Sunbelt market rates, not national averages that don't reflect the extreme-climate premium in AC-dependent cities.</p>
        </div>
        <div class="p-4">
          <div class="text-3xl mb-3">🌡️</div>
          <h3 class="font-semibold text-slate-800 mb-2">Climate-Specific Advice</h3>
          <p class="text-gray-600 text-sm">Each guide is tailored to your city's specific climate — what works for a Kansas City winter doesn't apply to a Yuma summer. We address both.</p>
        </div>
        <div class="p-4">
          <div class="text-3xl mb-3">🚫</div>
          <h3 class="font-semibold text-slate-800 mb-2">No Contractor Referrals</h3>
          <p class="text-gray-600 text-sm">We don't sell leads or refer contractors. Just honest information to help you make smarter decisions about your HVAC system.</p>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/ad-adsterra') %>

  <!-- FAQ Schema Section -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-800 mb-8 font-heading">Common HVAC Questions</h2>
      <div class="space-y-4">
        <details class="bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-slate-800 hover:bg-slate-100 transition-colors">How often should I service my AC?</summary>
          <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed">Once per year at minimum — ideally in spring before the cooling season begins. In Sunbelt cities with extreme heat, where AC units run 3,000–4,000+ hours per year, twice-annual service (spring for AC, fall for heating) is recommended. Annual maintenance extends equipment life and catches failing components before they cause emergency breakdowns.</div>
        </details>
        <details class="bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-slate-800 hover:bg-slate-100 transition-colors">How long do AC units last in hot climates?</summary>
          <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed">In Sunbelt cities like Yuma and Tucson, expect 12–15 years for a well-maintained central AC unit, compared to the national average of 15–20 years. The extreme runtime (3,000–4,000 hours/year vs. 1,500 in northern climates) accelerates component wear. Signs of end-of-life include frequent repairs, declining efficiency, and difficulty maintaining set temperature during heat waves.</div>
        </details>
        <details class="bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-slate-800 hover:bg-slate-100 transition-colors">When should I repair vs replace my AC?</summary>
          <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed">The standard rule: if repair cost exceeds 50% of replacement cost, replace. But in hot climates, also consider: system age (over 12–15 years → replace), refrigerant type (R-22 systems → replace, not recharge), and frequency of repairs (two+ repairs in a single season is a red flag). A new high-efficiency system often pays back in energy savings within 5–8 years in high-cooling-demand climates.</div>
        </details>
        <details class="bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-slate-800 hover:bg-slate-100 transition-colors">What SEER rating do I need in the Sunbelt?</summary>
          <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed">Minimum federal standard for Sunbelt states is 15 SEER2 for new installations (effective January 2023). For Sunbelt homes where cooling costs dominate the energy bill, 16–18 SEER2 delivers meaningful payback through energy savings. Variable-speed systems at 18–22 SEER2 are most efficient but cost $1,000–$3,000 more upfront. The higher the SEER2 rating, the faster the ROI in high-cooling climates.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- FAQ Schema Markup -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How often should I service my AC?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Once per year at minimum — ideally in spring before the cooling season begins. In Sunbelt cities with extreme heat, twice-annual service is recommended."
        }
      },
      {
        "@type": "Question",
        "name": "How long do AC units last in hot climates?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In Sunbelt cities like Yuma and Tucson, expect 12–15 years for a well-maintained central AC unit, compared to the national average of 15–20 years."
        }
      },
      {
        "@type": "Question",
        "name": "When should I repair vs replace my AC?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If repair cost exceeds 50% of replacement cost, replace. Also consider system age (over 12-15 years), refrigerant type, and frequency of repairs."
        }
      },
      {
        "@type": "Question",
        "name": "What SEER rating do I need in the Sunbelt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Minimum federal standard for Sunbelt states is 15 SEER2. For high-cooling climates, 16-18 SEER2 delivers meaningful payback through energy savings."
        }
      }
    ]
  }
  </script>

<%- include('../partials/footer', { cities, services, analyticsSlug }) %>
