    "seed:pdufa": "node pdufa/seed-data.js",
    "fda:pull": "node scripts/fda-outcome-pull.js"
  },
  "dependencies": {
    "ejs": "^5.0.1",
    "express": "^4.18.2",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "pg": "^8.11.3"
  }
}
